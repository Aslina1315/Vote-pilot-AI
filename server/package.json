{
  "name": "votepilot-server",
  "version": "1.0.0",
  "description": "VotePilot AI - Backend API Server",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit"
  },
  "keywords": [
    "voting",
    "ai",
    "election",
    "gemini"
  ],
