# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/votepilot?retryWrites=true&w=majority

# Google Gemini API Key (never expose in frontend)
GEMINI_API_KEY=your_gemini_api_key_here

# CORS - Frontend origin
CLIENT_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
